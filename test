bool touchHit(int x, int y, int w, int h) {
  if (!ts.touched()) return false;
  TS_Point p = ts.getPoint();
  // Uwaga: XPT2046 daje surowe współrzędne. Tu prosta normalizacja dla 320x240.
  // Może wymagać kalibracji w Twoim zestawie (zmień zakresy min/max).
  const int16_t RAW_MIN_X = 200, RAW_MAX_X = 3900;
  const int16_t RAW_MIN_Y = 200, RAW_MAX_Y = 3900;
  int16_t px = map(p.x, RAW_MIN_X, RAW_MAX_X, 0, tft.width());
  int16_t py = map(p.y, RAW_MIN_Y, RAW_MAX_Y, 0, tft.height());
  return (px >= x && px <= x + w && py >= y && py <= y + h);
}

// ====== OBD/ELM ======

bool elmWrite(const String& cmd) {
  if (!SerialBT.hasClient()) return false;
  SerialBT.print(cmd);
  SerialBT.print("\r");
  return true;
}

// Czytanie do \n lub ">" z timeoutem
bool elmReadLine(String& line, uint32_t timeoutMs = 500) {
  uint32_t t0 = millis();
  line = "";
  while (millis() - t0 < timeoutMs) {
    while (SerialBT.available()) {
      char c = (char)SerialBT.read();
      if (c == '\r') continue; // ignoruj CR
      if (c == '\n') {
        if (line.length()) return true; // zakończ linię
        else continue;
      }
      if (c == '>') {
        if (line.length()) return true; // prompt po danych
        else continue;
      }
      line += c;
    }
    delay(2);
  }
  return line.length();
}

// Parsowanie odpowiedzi "41 XX ..."
// Zwraca true, jeśli PID w odpowiedzi zgadza się z oczekiwanym.
bool parseOBD_41(const String& line, uint8_t pidExpected, uint8_t& A, uint8_t& B) {
  // Usuń spacje
  String s;
  s.reserve(line.length());
  for (char c : line) if (c != ' ') s += (char)toupper(c);

  // Szukamy nagłówka 41XX
  if (s.length() < 4) return false;
  if (s.substring(0, 2) != "41") return false;

  // PID na pozycjach 2-4 (hex)
  char pidStr[3] = { s[2], s[3], '\0' };
  uint8_t pid = (uint8_t) strtoul(pidStr, nullptr, 16);
  if (pid != pidExpected) return false;

  // Dane zaczynają się od następnych bajtów (A, B, ...)
  // Oczekujemy co najmniej 4 znaki na A i 4 na B (2 hexy = 1 bajt)
  if (s.length() < 6) return false;
  if (s.length() >= 6) {
    char aStr[3] = { s[4], s[5], '\0' };
    A = (uint8_t) strtoul(aStr, nullptr, 16);
  }
  if (s.length() >= 8) {
    char bStr[3] = { s[6], s[7], '\0' };
    B = (uint8_t) strtoul(bStr, nullptr, 16);
  } else {
    B = 0;
  }
  return true;
}

// Wysyła zapytanie o PID i czeka na linię z odpowiedzią
bool requestPID(uint8_t pid, uint8_t& A, uint8_t& B) {
  String cmd = "01" + String(pid, HEX);
  cmd.toUpperCase();
  elmWrite(cmd);

  // ELM może zwrócić kilka linii (nagłówki). Zbieramy do skutku.
  String line;
  uint32_t t0 = millis();
  while (millis() - t0 < 700) {
    if (elmReadLine(line, 300)) {
      if (line.indexOf("NO DATA") >= 0) return false;
      if (line.indexOf("STOPPED") >= 0) return false;
      if (line.indexOf("ERROR") >= 0) return false;
      uint8_t a=0,b=0;
      if (parseOBD_41(line, pid, a, b)) { A=a; B=b; return true; }
    }
  }
  return false;
}

// Konwersje PID
void updateFastPIDs() {
  uint8_t A, B;
  // 010C RPM = ((A*256)+B)/4
  if (requestPID(0x0C, A, B)) {
    obd.rpm = ((A * 256) + B) / 4;
  }
  // 010D speed km/h = A
  if (requestPID(0x0D, A, B)) {
    obd.speed = A;
  }
}

void updateSlowPIDs() {
  uint8_t A, B;
  // 0105 coolant temp = A - 40
  if (requestPID(0x05, A, B)) obd.coolant = (int)A - 40;
  // 010F intake air temp = A - 40
  if (requestPID(0x0F, A, B)) obd.iat = (int)A - 40;
  // 0111 throttle position = A * 100 / 255
  if (requestPID(0x11, A, B)) obd.throttle = (int)((A * 100UL) / 255UL);
  // 012F fuel level = A * 100 / 255
  if (requestPID(0x2F, A, B)) obd.fuelLevel = (int)((A * 100UL) / 255UL);
  // 0104 engine load = A * 100 / 255
  if (requestPID(0x04, A, B)) obd.load = (int)((A * 100UL) / 255UL);
  // 010B MAP = A (kPa)
  if (requestPID(0x0B, A, B)) obd.map = A;
  // 0110 MAF = ((256*A)+B)/100  (g/s)
  if (requestPID(0x10, A, B)) obd.maf = (int)(((256UL * A) + B) / 100UL);
}

bool elmInit() {
  // Najpierw spróbuj podłączyć do zapamiętanego/znalezionego urządzenia po nazwie
  SerialBT.begin("ESP32-OBD");
  delay(300);
  if (!SerialBT.connect(ELM_BT_NAME)) {
    // Jeśli nie łączy od razu, spróbuj w pętli przez krótki czas
    uint32_t t0 = millis();
    while (!SerialBT.connected() && millis() - t0 < 8000) {
      SerialBT.connect(ELM_BT_NAME);
      delay(500);
    }
  }
  if (!SerialBT.connected()) return false;

  auto sendAT = [&](const char* at, uint32_t waitMs = 300) {
    elmWrite(at);
    String line;
    uint32_t t0 = millis();
    while (millis() - t0 < waitMs) {
      if (elmReadLine(line, waitMs)) {
        // Możesz wypisać do Serial w trybie debug
      }
    }
  };

  sendAT("ATZ", 800);   // reset ELM
  sendAT("ATE0", 200);  // echo off
  sendAT("ATL0", 200);  // linefeeds off
  sendAT("ATS0", 200);  // printing spaces off
  sendAT("ATH1", 200);  // headers on (pomocne w debug)
  sendAT("ATSP0", 300); // auto protocol (lub ATSP6 dla CAN 11-bit 500k)
  // opcjonalnie: szybki tryb CAN
  // sendAT("ATCAF0", 200); // CAN auto formatting off (czasem pomaga)

  // Test — dostępne PID-y
  elmWrite("0100");
  String line; elmReadLine(line, 600);

  return true;
}

void drawAll() {
  if (currentPage == PAGE_MAIN) drawMainPage();
  else drawExtraPage();
}

void setup() {
  // Serial debug opcjonalnie
  Serial.begin(115200);
  delay(200);

  // SPI i wyświetlacz
  // Jeśli używasz HSPI: SPI.begin(SPI_SCLK, SPI_MISO, SPI_MOSI);
  tft.begin();
  tft.setRotation(1); // poziomo
  tft.fillScreen(ILI9341_BLACK);

  // Dotyk
  ts.begin();
  ts.setRotation(1);

  tftHeader("ELM327 — Connecting...");
  tft.setTextColor(ILI9341_WHITE);
  tft.setTextSize(2);
  tft.setCursor(10, 40);
  tft.print("BT: "); tft.print(ELM_BT_NAME);

  if (!elmInit()) {
    tft.setCursor(10, 70);
    tft.setTextColor(ILI9341_RED);
    tft.print("Nie polaczono z ELM!");
  } else {
    tft.setCursor(10, 70);
    tft.setTextColor(ILI9341_GREEN);
    tft.print("Polaczono.");
  }

  delay(500);
  drawAll();
}

void loop() {
  uint32_t now = millis();

  // Szybkie PID-y
  if (now - tFast >= POLL_FAST_MS && SerialBT.connected()) {
    tFast = now;
    updateFastPIDs();
    if (currentPage == PAGE_MAIN) drawMainPage();
  }

  // Wolniejsze PID-y
  if (now - tSlow >= POLL_SLOW_MS && SerialBT.connected()) {
    tSlow = now;
    updateSlowPIDs();
    if (currentPage == PAGE_EXTRA) drawExtraPage();
  }

  // Obsługa dotyku — przełącznik stron
  if (ts.touched()) {
    if (currentPage == PAGE_MAIN) {
      if (touchHit(10, 220, 90, 20)) { currentPage = PAGE_EXTRA; drawAll(); delay(250); }
    } else {
      if (touchHit(10, 220, 110, 20)) { currentPage = PAGE_MAIN; drawAll(); delay(250); }
    }
  }

  // Utrata połączenia — spróbuj ponownie
  static uint32_t tReconnect = 0;
  if (!SerialBT.connected() && (now - tReconnect > 2000)) {
    tReconnect = now;
    SerialBT.connect(ELM_BT_NAME);
  }
}

