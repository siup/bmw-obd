// Stan GUI
enum Page { PAGE_MAIN = 0, PAGE_EXTRA = 1 };
Page currentPage = PAGE_MAIN;

// Bufory
String elmBuffer;

// Dane PID
struct ObdData {
  int rpm = -1;       // 010C
  int speed = -1;     // 010D (km/h)
  int coolant = -128; // 0105 (°C)
  int iat = -128;     // 010F (°C)
  int throttle = -1;  // 0111 (%)
  int fuelLevel = -1; // 012F (%)
  int load = -1;      // 0104 (%)
  int map = -1;       // 010B (kPa)
  int maf = -1;       // 0110 (g/s)
} obd;

// Timery
uint32_t tFast = 0;
uint32_t tSlow = 0;

