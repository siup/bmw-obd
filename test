const uint32_t SPI_FREQ_TOUCH = 2000000; // 2 MHz dla XPT2046

// Interwały odświeżania
const uint32_t POLL_FAST_MS = 200;   // szybkie PID-y (RPM, prędkość)
const uint32_t POLL_SLOW_MS = 800;   // wolniejsze PID-y (temp itd.)

// ====== OBIEKTY GLOBALNE ======
BluetoothSerial SerialBT;
Adafruit_ILI9341 tft(TFT_CS, TFT_DC, TFT_RST);
